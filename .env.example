# TutorSpace — Environment Variables
# Copy this file to .env.local and fill in your Supabase credentials

# Get these from: https://supabase.com/dashboard → Your Project → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
VITE_BOT_USERNAME=YOUR_BOT_USERNAME_HERE
VITE_BACKEND_URL=https://YOUR_BOT_BACKEND_DOMAIN

# Your Telegram ID — only this user can register as teacher
# Get it by sending /start to @userinfobot on Telegram
VITE_ADMIN_TELEGRAM_ID=YOUR_TELEGRAM_ID_HERE
